{
  "name": "@traccia/sdk",
  "version": "0.1.1",
  "description": "Tracing SDK for agent applications",
  "main": "dist/index.js",
  "bin": {
    "traccia-ts": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./auto": {
      "import": {
        "types": "./dist/auto.d.mts",
        "default": "./dist/auto.mjs"
      },
      "require": {
        "types": "./dist/auto.d.ts",
        "default": "./dist/auto.js"
      }
    },
    "./tracer": {
      "import": {
        "types": "./dist/tracer/index.d.mts",
        "default": "./dist/tracer/index.mjs"
      },
      "require": {
        "types": "./dist/tracer/index.d.ts",
        "default": "./dist/tracer/index.js"
      }
    },
    "./integrations": {
      "import": {
        "types": "./dist/integrations/index.d.mts",
        "default": "./dist/integrations/index.mjs"
      },
      "require": {
        "types": "./dist/integrations/index.d.ts",
        "default": "./dist/integrations/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "tracing",
    "observability",
    "agent",
    "governance",
    "instrumentation",
    "opentelemetry"
  ],
  "author": "Traccia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traccia-ai/traccia-node.git"
  },
  "bugs": {
    "url": "https://github.com/traccia-ai/traccia-node/issues"
  },
  "homepage": "https://github.com/traccia-ai/traccia-node#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@langchain/core": ">=0.3.8",
    "@opentelemetry/api": "^1.9.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-ctrf-json-reporter": "^0.0.11",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.7",
    "toml": "^3.0.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.8",
    "@opentelemetry/api": "^1.9.0"
  },
  "dependencies": {
    "@opentelemetry/core": "^2.5.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-trace-base": "^2.5.0",
    "axios": "^1.7.2",
    "commander": "^12.0.0",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "protobufjs": "^8.0.2",
    "esbuild": "^0.28.1",
    "minimatch": "^9.0.9"
  }
}
