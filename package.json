{
  "name": "@traccia/sdk",
  "version": "0.0.1",
  "description": "Tracing SDK for agent applications",
  "main": "dist/index.js",
  "bin": {
    "traccia-ts": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auto": {
      "import": "./dist/auto.js",
      "require": "./dist/auto.js",
      "types": "./dist/auto.d.ts"
    },
    "./tracer": {
      "import": "./dist/tracer/index.js",
      "require": "./dist/tracer/index.js",
      "types": "./dist/tracer/index.d.ts"
    },
    "./integrations": {
      "import": "./dist/integrations/index.js",
      "require": "./dist/integrations/index.js",
      "types": "./dist/integrations/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "tracing",
    "observability",
    "agent",
    "instrumentation",
    "opentelemetry"
  ],
  "author": "Traccia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traccia/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/traccia/sdk-ts/issues"
  },
  "homepage": "https://github.com/traccia/sdk-ts#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@langchain/core": ">=0.3.8",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.7",
    "toml": "^3.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.8",
    "@opentelemetry/api": "^1.9.0"
  },
  "dependencies": {
    "@opentelemetry/core": "^2.5.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-trace-base": "^2.5.0",
    "axios": "^1.7.2",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  }
}